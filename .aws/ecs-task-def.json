{
  "family": "versapath-user-management-service",
  "taskRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "user-management-service",
      "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/versapath/user-management-service:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8090,
          "hostPort": 8090,
          "protocol": "tcp",
          "name": "user-management-service"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SERVER_PORT",
          "value": "8090"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "docker"
        },
        {
          "name": "EUREKA_CLIENT_URL",
          "value": "http://service-discovery:8761/eureka"
        },
        {
          "name": "CONFIG_SERVER_URL",
          "value": "http://config-server:8888"
        },
        {
          "name": "SPRING_APPLICATION_NAME",
          "value": "user-management-service"
        },
        {
          "name": "SPRING_REDIS_HOST",
          "value": "versapath-redis-public.qhppxi.cache.amazonaws.com"
        },
        {
          "name": "SPRING_REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://versapath-rds-public.c74djmqdddtw.eu-west-1.rds.amazonaws.com:5432/versapath_db"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "value": "versapath_user"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "value": "versapath2024"
        },
        {
          "name": "SPRING_JPA_HIBERNATE_DDL_AUTO",
          "value": "update"
        },
        {
          "name": "SPRING_JPA_DATABASE_PLATFORM",
          "value": "org.hibernate.dialect.PostgreSQLDialect"
        },
        {
          "name": "JWT_SECRET",
          "value": "9EcwH9tPJZWyI785B2ow/kfmlFxGfkHC+qadKHGKNRgvuLgJcW4RwoPf0tTYBUIf"
        },
        {
          "name": "JWT_ACCESS_TOKEN_EXPIRATION_MS",
          "value": "900000"
        },
        {
          "name": "JWT_REFRESH_TOKEN_EXPIRATION_MS",
          "value": "604800000"
        },
        {
          "name": "APP_SECURITY_SECURE_COOKIES",
          "value": "true"
        },
        {
          "name": "APP_SECURITY_COOKIE_PATH",
          "value": "/api/v1/auth"
        },
        {
          "name": "SPRING_MAIL_HOST",
          "value": "smtp.mailtrap.io"
        },
        {
          "name": "SPRING_MAIL_USERNAME",
          "value": "7534968b44428b"
        },
        {
          "name": "SPRING_MAIL_PASSWORD",
          "value": "b6c71d14c804e3"
        },
        {
          "name": "SPRING_MAIL_PORT",
          "value": "2525"
        },
        {
          "name": "REGISTRATION_EMAIL_BODY_FILE",
          "value": "email/registration-invitation.html"
        },
        {
          "name": "APP_BASE_URL",
          "value": "http://versapath-alb-1040585484.eu-west-1.elb.amazonaws.com"
        },
        {
          "name": "APP_NOTIFICATION_EMAIL_FROM",
          "value": "noreply@versapath.com"
        },
        {
          "name": "APP_NOTIFICATION_EMAIL_SUBJECT_PREFIX",
          "value": "[VersaPath]"
        },
        {
          "name": "APP_PASSWORD_RESET_FE_URI",
