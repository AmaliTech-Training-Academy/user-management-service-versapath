      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/versapath/user-management-service",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "user-management-service"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8090/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 15,
        "retries": 5,
        "startPeriod": 300
      },
      "systemControls": []
    }
  ],
  "volumes": [],
  "placementConstraints": []
}
